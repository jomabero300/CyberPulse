@page "/productos"
@inject HttpClient Http

<h3>Productos</h3>

<button @onclick="MostrarReporte1">Ver PDF</button>

@if (productos == null)
{
    <p>Cargando...</p>
}
else
{
    <ul>
        @foreach (var p in productos)
        {
            <li>@p.Nombre (@p.Cantidad)</li>
        }
    </ul>
}

@code {
    [Inject] IJSRuntime JS { get; set; }
    //    [Inject] public IJSRuntime JS { get; set; }
    List<Producto> productos;

    protected override async Task OnInitializedAsync()
    {
        productos = await Http.GetFromJsonAsync<List<Producto>>("api/productos");
    }

    async Task DescargarReporte()
    {
        var bytes = await Http.GetByteArrayAsync("api/productos/reporte");
        var fileName = "reporte_productos.pdf";

        using var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
        //await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
        await JS.InvokeVoidAsync("open", fileName, streamRef);
    }
    async Task MostrarReporte()
    {
        // Obtener el archivo PDF desde la API
        var bytes = await Http.GetByteArrayAsync("api/productos/reporte");

        // Convertir los bytes a Base64
        var base64Pdf = Convert.ToBase64String(bytes);

        // Crear el URL del PDF con el formato Base64
        var pdfDataUrl = $"data:application/pdf;base64,{base64Pdf}";

        // Abrir el PDF en una nueva pestaña
        await JS.InvokeVoidAsync("open", pdfDataUrl, "_blank");
    }

